generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  ownerUserId  String?  @map("owner_user_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members               Member[]
  planTypes             PlanType[]
  trainers              Trainer[]
  dailySnapshots        DailyActivitySnapshot[]
  expenses              Expense[]
  investments           Investment[]
  attendances           Attendance[]
  attendanceHourlySnapshots AttendanceHourlySnapshot[]
  trainerPayouts        TrainerPayout[]
  notificationSettings  OrgNotificationSettings?
  staffPermissions      OrgStaffPermissions?
  offers                Offer[]

  @@map("organizations")
}

model Member {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  clerkUserId   String?   @map("clerk_user_id")
  firstName     String    @map("first_name")
  middleName    String?   @map("middle_name")
  lastName      String    @map("last_name")
  phone         String
  email         String
  dateOfBirth   DateTime  @map("date_of_birth")
  gender        String
  joinDate      DateTime  @map("join_date")
  notes              String?
  isActive           Boolean   @default(true) @map("is_active")
  referredById       String?   @map("referred_by_id")
  whatsappOptedIn    Boolean   @default(false) @map("whatsapp_opted_in")
  welcomeSentAt      DateTime? @map("welcome_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [orgId], references: [id])
  memberships   Membership[]
  trainings     Training[]
  payments      Payment[]
  attendances   Attendance[]
  referredBy    Member?      @relation("MemberReferrals", fields: [referredById], references: [id])
  referrals     Member[]     @relation("MemberReferrals")

  @@index([orgId])
  @@index([phone])
  @@index([clerkUserId])
  @@map("members")
}

model PlanType {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  category    PlanCategory @default(membership)

  organization Organization   @relation(fields: [orgId], references: [id])
  variants     PlanVariant[]

  @@index([orgId])
  @@index([isActive])
  @@index([category])
  @@map("plan_types")
}

model PlanVariant {
  id            String   @id @default(uuid())
  planTypeId    String   @map("plan_type_id")
  durationDays  Int      @map("duration_days")
  durationLabel String   @map("duration_label")
  price         Float
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  // Trainer payout defaults (only relevant for training-category variants)
  defaultTrainerSplitPercent Float? @map("default_trainer_split_percent")
  defaultTrainerFixedPayout  Float? @map("default_trainer_fixed_payout")

  planType    PlanType     @relation(fields: [planTypeId], references: [id], onDelete: Cascade)
  memberships Membership[]
  trainings   Training[]

  offersAsMembership Offer[] @relation("OfferMembershipVariant")
  offersAsTraining   Offer[] @relation("OfferTrainingVariant")

  @@index([planTypeId])
  @@index([isActive])
  @@map("plan_variants")
}

enum PlanCategory {
  membership
  training
}

enum MembershipStatus {
  active
  expired
  cancelled
  frozen
}

enum TrainingStatus {
  active
  expired
  cancelled
  frozen
}

enum PaymentMethod {
  cash
  card
  upi
  bank_transfer
  other
}

enum PaymentStatus {
  paid
  pending
  failed
  refunded
}

model Membership {
  id              String           @id @default(uuid())
  orgId           String           @map("org_id")
  memberId        String           @map("member_id")
  planVariantId   String           @map("plan_variant_id")
  startDate       DateTime         @map("start_date")
  endDate         DateTime         @map("end_date")
  status          MembershipStatus @default(active)
  priceAtPurchase Float            @map("price_at_purchase")
  discountAmount  Float            @default(0) @map("discount_amount")
  finalPrice      Float            @map("final_price")
  autoRenew       Boolean          @default(false) @map("auto_renew")
  notes           String?
  freezeReason    String?          @map("freeze_reason")
  freezeStartDate DateTime?        @map("freeze_start_date")
  freezeEndDate   DateTime?        @map("freeze_end_date")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  offerId         String?  @map("offer_id")

  member      Member      @relation(fields: [memberId], references: [id])
  planVariant PlanVariant @relation(fields: [planVariantId], references: [id])
  offer       Offer?      @relation(fields: [offerId], references: [id])
  payments    Payment[]

  @@index([memberId])
  @@index([status])
  @@index([endDate])
  @@index([orgId, status])
  @@map("memberships")
}

model Training {
  id              String         @id @default(uuid())
  orgId           String         @map("org_id")
  memberId        String         @map("member_id")
  planVariantId   String         @map("plan_variant_id")
  trainerId       String         @map("trainer_id")
  startDate       DateTime       @map("start_date")
  endDate         DateTime       @map("end_date")
  status          TrainingStatus @default(active)
  priceAtPurchase Float          @map("price_at_purchase")
  discountAmount  Float          @default(0) @map("discount_amount")
  finalPrice      Float          @map("final_price")
  autoRenew           Boolean        @default(false) @map("auto_renew")
  notes               String?
  trainerFixedPayout  Float?         @map("trainer_fixed_payout")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  offerId         String?  @map("offer_id")

  member      Member          @relation(fields: [memberId], references: [id])
  planVariant PlanVariant     @relation(fields: [planVariantId], references: [id])
  trainer     Trainer         @relation(fields: [trainerId], references: [id])
  offer       Offer?          @relation(fields: [offerId], references: [id])
  payments    Payment[]
  payouts     TrainerPayout[]

  @@index([memberId])
  @@index([status])
  @@index([endDate])
  @@index([trainerId])
  @@map("trainings")
}

model Trainer {
  id           String  @id @default(uuid())
  orgId        String  @map("org_id")
  name         String
  splitPercent Float   @default(60) @map("split_percent")
  isActive     Boolean @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [orgId], references: [id])
  trainings    Training[]
  payouts      TrainerPayout[]

  @@index([orgId])
  @@index([isActive])
  @@map("trainers")
}

model TrainerPayout {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  trainerId    String   @map("trainer_id")
  trainingId   String   @map("training_id")
  month        Int
  year         Int
  revenueBase  Float    @map("revenue_base")
  splitPercent Float    @default(60) @map("split_percent")
  amount       Float
  notes        String?
  paidAt       DateTime @default(now()) @map("paid_at")
  createdAt    DateTime @default(now()) @map("created_at")

  trainer  Trainer      @relation(fields: [trainerId], references: [id])
  training Training     @relation(fields: [trainingId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id])

  @@unique([trainingId, month, year])
  @@index([trainerId])
  @@index([orgId])
  @@map("trainer_payouts")
}

model Payment {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  memberId     String        @map("member_id")
  membershipId String?       @map("membership_id")
  trainingId   String?       @map("training_id")
  amount       Float
  method       PaymentMethod
  status       PaymentStatus @default(pending)
  reference    String?
  notes        String?
  paidAt       DateTime?     @map("paid_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  member     Member      @relation(fields: [memberId], references: [id])
  membership Membership? @relation(fields: [membershipId], references: [id])
  training   Training?   @relation(fields: [trainingId], references: [id])

  @@index([memberId])
  @@index([membershipId])
  @@index([trainingId])
  @@index([orgId, paidAt])
  @@map("payments")
}

// ─── Cron: Daily activity snapshots ───────────────────────────────────────────

model DailyActivitySnapshot {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  snapshotDate    DateTime @db.Date @map("snapshot_date")
  totalMembers    Int      @map("total_members")
  activeMembers   Int      @map("active_members")
  inactiveMembers Int      @map("inactive_members")
  newlyExpired    Int      @map("newly_expired")
  createdAt       DateTime @default(now()) @map("created_at")

  org             Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, snapshotDate])
  @@index([orgId])
  @@map("daily_activity_snapshots")
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  memberId   String    @map("member_id")
  entryTime  DateTime  @map("entry_time")
  exitTime   DateTime? @map("exit_time")
  date       DateTime  @db.Date
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  member     Member       @relation(fields: [memberId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([memberId])
  @@index([date])
  @@index([orgId, date])
  @@index([orgId, exitTime])
  @@index([orgId, memberId, exitTime])
  @@map("attendances")
}

// Pre-computed daily hourly check-in counts for efficient avg queries
model AttendanceHourlySnapshot {
  id     String   @id @default(uuid())
  orgId  String   @map("org_id")
  date   DateTime @db.Date
  hour   Int      // 0–23
  count  Int      @default(0)

  org    Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, date, hour])
  @@index([orgId])
  @@map("attendance_hourly_snapshots")
}

// ─── Financials ───────────────────────────────────────────────────────────────

enum ExpenseCategory {
  rent
  utilities
  staff
  equipment
  marketing
  maintenance
  other
}

model Expense {
  id          String          @id @default(uuid())
  orgId       String          @map("org_id")
  amount      Float
  category    ExpenseCategory @default(other)
  description String?
  date        DateTime        @db.Date
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([date])
  @@index([orgId, date])
  @@map("expenses")
}

model Investment {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  amount    Float
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("investments")
}

// ─── Offers ───────────────────────────────────────────────────────────────────

enum OfferType {
  event
  referral
  discount
  promo
}

enum DiscountType {
  flat
  percentage
}

enum OfferAppliesTo {
  membership
  training
  both
}

model Offer {
  id            String          @id @default(uuid())
  orgId         String          @map("org_id")
  type          OfferType
  title         String
  description   String?
  startDate     DateTime?       @map("start_date")
  endDate       DateTime?       @map("end_date")
  isActive      Boolean         @default(true) @map("is_active")
  discountType  DiscountType?   @map("discount_type")
  discountValue Float?          @map("discount_value")
  code          String?
  rewardAmount  Float?          @map("reward_amount")
  appliesTo     OfferAppliesTo  @default(membership) @map("applies_to")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Package configuration — smart offer fields
  targetGender              String?  @map("target_gender")
  membershipPlanVariantId   String?  @map("membership_plan_variant_id")
  trainingPlanVariantId     String?  @map("training_plan_variant_id")
  targetPrice               Float?   @map("target_price")
  trainerFixedPayout        Float?   @map("trainer_fixed_payout")
  trainerSplitPercent       Float?   @map("trainer_split_percent")

  org                    Organization @relation(fields: [orgId], references: [id])
  membershipPlanVariant  PlanVariant? @relation("OfferMembershipVariant", fields: [membershipPlanVariantId], references: [id])
  trainingPlanVariant    PlanVariant? @relation("OfferTrainingVariant", fields: [trainingPlanVariantId], references: [id])
  memberships            Membership[]
  trainings              Training[]

  @@index([orgId])
  @@index([type])
  @@index([isActive])
  @@map("offers")
}

// ─── Staff Permissions ────────────────────────────────────────────────────────

model OrgStaffPermissions {
  id                    String   @id @default(uuid())
  orgId                 String   @unique @map("org_id")
  canTakeAttendance     Boolean  @default(true)  @map("can_take_attendance")
  canRegisterMember     Boolean  @default(false) @map("can_register_member")
  canCreateMembership   Boolean  @default(false) @map("can_create_membership")
  canCreateTraining     Boolean  @default(false) @map("can_create_training")
  canRecordPayment      Boolean  @default(false) @map("can_record_payment")
  canViewMembers        Boolean  @default(true)  @map("can_view_members")
  canViewReports        Boolean  @default(false) @map("can_view_reports")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@map("org_staff_permissions")
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model OrgNotificationSettings {
  id                      String   @id @default(uuid())
  orgId                   String   @unique @map("org_id")
  ownerWhatsapp           String?  @map("owner_whatsapp")
  digestEnabled           Boolean  @default(false) @map("digest_enabled")
  memberReminderEnabled   Boolean  @default(false) @map("member_reminder_enabled")
  reminderDaysBefore      Int      @default(3) @map("reminder_days_before")
  // Welcome message
  welcomeEnabled          Boolean  @default(false) @map("welcome_enabled")
  welcomeMessage          String?  @map("welcome_message")
  // Dues reminder
  duesReminderEnabled     Boolean  @default(false) @map("dues_reminder_enabled")
  duesReminderDaysOld     Int      @default(7) @map("dues_reminder_days_old")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@map("org_notification_settings")
}
